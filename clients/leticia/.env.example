# ================================
# Bot Letícia Estética — Variáveis de Ambiente
# KAIROS AI OPS · Railway Deploy
# ================================

# Porta (Railway define automaticamente via $PORT)
PORT=3000

# ── GROQ (LLM) — OBRIGATÓRIO ──
GROQ_API_KEY=sua_groq_api_key_aqui
# Dica: use uma das 84 keys do God Pool

# ── EVOLUTION API (WhatsApp) — OBRIGATÓRIO ──
EVOLUTION_API_URL=https://sua-evolution.up.railway.app
EVOLUTION_GLOBAL_APIKEY=sua_global_api_key
INSTANCE_NAME=leticia-estetica
# O nome da instância deve existir na sua Evolution API

# ── TELEGRAM (Sócio Digital Gabriel) — OPCIONAL ──
# Crie um bot no @BotFather e cole o token abaixo
TELEGRAM_BOT_TOKEN=
# Seu chat ID no Telegram (mande /start para @userinfobot para descobrir)
TELEGRAM_OWNER_ID=

# ── SEGURANÇA WEBHOOK — OPCIONAL ──
# String aleatória para validar requisições do webhook
WEBHOOK_SECRET=

# ── LLM TUNING — OPCIONAL (defaults já configurados) ──
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE_ATTENDANT=0.8
# LLM_MAX_TOKENS_ATTENDANT=180
